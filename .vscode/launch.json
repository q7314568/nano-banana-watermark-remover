{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Tauri Development",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/app/src-tauri/target/debug/app.exe",
            "args": [],
            "cwd": "${workspaceFolder}/app",
            "preLaunchTask": "dev:all",
            "env": {
                "WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS": "--remote-debugging-port=1420",
                "RUST_LOG": "debug,tauri=debug"
            },
            "sourceLanguages": [
                "rust"
            ]
        }
    ]
}