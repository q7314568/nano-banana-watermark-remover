{
    "manifest_version": 3,
    "name": "Nano Banana Watermark Remover",
    "version": "1.0",
    "description": "Remove watermarks from images efficiently.",
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "assets/bg_48.png",
            "48": "assets/bg_48.png",
            "128": "assets/bg_96.png"
        }
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    },
    "permissions": [
        "activeTab",
        "downloads"
    ]
}